<dialog id="turbo-confirm-dialog"
  class="bg-white border border-slate-200 rounded-xl shadow-xl"
  style="position: fixed; inset: 0; margin: auto; width: 100%; max-width: 400px; padding: 0;">
  <style>
    #turbo-confirm-dialog::backdrop {
      background: rgba(0, 0, 0, 0.45);
    }
  </style>

  <div class="p-6">
    <p class="text-base font-medium mb-2">
      Are you sure?
    </p>

    <p
      id="turbo-confirm-message"
      class="text-sm text-slate-500 leading-relaxed mb-6"
    ></p>

    <div class="flex justify-end gap-2">
      <button
        id="turbo-confirm-cancel"
        type="button"
        class="text-sm font-medium px-4 py-2 rounded-lg border
               border-slate-200 cursor-pointer"
      >
        Cancel
      </button>

      <button
        id="turbo-confirm-ok"
        type="button"
        class="text-sm font-medium bg-emerald-500 hover:bg-emerald-600
               text-white px-4 py-2 rounded-lg transition-colors cursor-pointer"
      >
        Remove
      </button>
    </div>
  </div>
</dialog>
