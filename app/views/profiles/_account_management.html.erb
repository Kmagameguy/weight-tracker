<div class="max-w-xl mx-auto px-2 py-4 flex flex-col gap-5">
  <div class="bg-white shadow-sm border border-slate-200 rounded-lg p-4">
    <h2 class="font-semibold text-slate-800 mb-4">Account Management</h2>
    <%= form_with model: user, url: profile_path, method: :patch do |f| %>

      <div class="mb-6">
        <h3 class="text-sm font-medium text-slate-700 mb-2">Time Zone</h3>
        <%= f.select(
              :timezone,
              ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.tzinfo.name] },
              {},
              class: "w-full text-sm rounded-lg border border-slate-200 px-3 py-2 bg-white
                      text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-400") %>
      </div>

      <div class="mb-6">
        <h3 class="text-sm font-medium text-slate-700 mb-2">Daily Calorie Goal</h3>
        <div class="text-xs text-slate-400 mb-2">
          Current goal: <%= number_with_delimiter(user.daily_calorie_goal) %>
        </div>
        <%= f.number_field :daily_calorie_goal,
              min: 1,
              required: true,
              class: "w-40 text-sm rounded-lg border border-slate-200 px-3 py-2
                      text-slate-700 placeholder-slate-300
                      focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
      </div>

      <div class="mb-6">
        <h3 class="text-sm font-medium text-slate-700 mb-2">Enable & Disable Features</h3>
        <p class="text-xs text-slate-400 mb-3">
          Saved calorie counts, weight entries, and blood pressure readings will still exist when disabling a feature.
        </p>

        <div class="flex flex-col gap-1">
          <% [
            [:calorie_tracking_enabled,        "Calorie Tracking"],
            [:weight_tracking_enabled,         "Weight Tracking"],
            [:blood_pressure_tracking_enabled, "Blood Pressure Tracking"],
          ].each do |attr, label_text| %>
            <%= f.label attr,
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-lg cursor-pointer
                          bg-slate-50 hover:bg-slate-100 transition-colors
                          has-[:checked]:bg-slate-200 group" do %>
              <%= f.check_box attr,
                    class: "appearance-none shrink-0 h-4 w-4 rounded border border-slate-300
                            bg-white cursor-pointer transition-colors relative
                            checked:bg-slate-600 checked:border-slate-600
                            focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-1" %>
              <span class="text-sm text-slate-500 select-none transition-colors
                           group-has-[:checked]:text-slate-800 group-has-[:checked]:font-medium">
                <%= label_text %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="flex items-center justify-between pt-3 border-t border-slate-100">
        <%= link_to "Reset Password", new_password_path,
              class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
        <%= f.submit "Update Settings",
              class: "text-sm font-medium bg-emerald-500 hover:bg-emerald-600 text-white
                      px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
