<% if presenter.weights_present? %>
  <div class="max-w-xl mx-auto px-2 py-3 flex flex-col gap-4">
    <div class="bg-white shadow-sm border border-slate-100 rounded-lg p-4">
      <%= line_chart presenter.data,
            title: presenter.title,
            min: presenter.y_axis_min,
            max: presenter.y_axis_max  %>
    </div>
  </div>
<% end %>
