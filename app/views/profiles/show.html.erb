<div class="max-w-xl mx-auto px-2 py-4 flex flex-col gap-5">
  <% if flash[:notice] %>
    <div class="px-4 py-3 bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm rounded-lg">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="bg-white shadow-sm border border-slate-200 rounded-lg p-4">
    <h2 class="font-semibold text-slate-800 mb-4">Account Management</h2>
    <%= form_with model: @user, url: profile_path, method: :patch do |f| %>
      <div class="mb-6">
        <h3 class="text-sm font-medium text-slate-700 mb-2">Time Zone</h3>
        <%= f.select(
              :timezone,
              ActiveSupport::TimeZone.all.map { |tz| [tz.to_s, tz.tzinfo.name] },
              {},
              class: "w-full text-sm rounded-lg border border-slate-200 px-3 py-2 bg-white
                      text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-400") %>
      </div>

      <div class="mb-6">
        <h3 class="text-sm font-medium text-slate-700 mb-2">Daily Calorie Goal</h3>
        <div class="text-xs text-slate-400 mb-2">
          Current goal: <%= number_with_delimiter(@user.daily_calorie_goal) %>
        </div>
        <%= f.number_field :daily_calorie_goal,
              min: 1,
              required: true,
              class: "w-40 text-sm rounded-lg border border-slate-200 px-3 py-2
                      text-slate-700 placeholder-slate-300
                      focus:outline-none focus:ring-2 focus:ring-emerald-400" %>
      </div>
      <div class="flex items-center justify-between pt-3 border-t border-slate-100">
        <%= link_to "Reset Password", new_password_path,
              class: "text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
        <%= f.submit "Update Settings",
              class: "text-sm font-medium bg-emerald-500 hover:bg-emerald-600 text-white
                      px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

<div class="max-w-xl mx-auto px-2 py-3 flex flex-col gap-4">
  <div class="bg-white shadow-sm border border-slate-100 p-4">
    <h3 class="font-semibold text-slate-800 mb-2">Statistics</h3>
    <div class="flex justify-between text-sm mb-1">
      <span class="text-slate-400">Daily goal:</span>
      <span class="font-medium"><%= number_with_delimiter(@user.daily_calorie_goal) %> cal</span>
    </div>
    <div class="flex justify-between text-sm mb-1">
      <span class="text-slate-400">Days over budget:</span>
      <span class="font-medium"><%= number_with_delimiter(@days_over_budget) %></span>
    </div>
    <div class="flex justify-between text-sm mb-1">
      <span class="text-slate-400">Median calorie intake:</span>
      <span class="font-medium"><%= number_with_delimiter(@user.median_calories_consumed.round(0)) %> cal</span>
    </div>
    <div class="flex justify-between text-sm mb-1">
      <span class="text-slate-400">Calorie <%= @calorie_deficit.positive? ? "deficit" : "surplus" %> since start (based on typical 2,000 calorie diet):</span>
      <span class="font-medium"><%= number_with_delimiter(@calorie_deficit.to_i.abs) %></span>
    </div>
    <div class="flex justify-between text-sm mb-1">
      <span class="text-slate-400">Last weigh-in:</span>
      <% weight = @user.weight_entries.max_by(&:date)&.weight %>
      <span class="font-medium"><%= weight.present? ? "#{number_with_precision(weight, precision: 1)} lbs" : "No weigh-ins available" %></span>
    </div>
  </div>
</div>

<% if @user.weight_entries.exists? %>
  <div class="max-w-xl mx-auto px-2 py-3 flex flex-col gap-4">
    <div class="bg-white shadow-sm border border-slate-100 p-4">
      <%
        weights_by_date = @user.weight_entries.order(:date).pluck(:date, :weight).to_h
        min, max = weights_by_date.values.minmax.map(&:to_i)
      %>
      <%= line_chart weights_by_date,
            title: "Weight Change Over Time (lbs)",
            min: min - 10,
            max: max + 10  %>
    </div>
  </div>
<% end %>

<% if @user.food_entries.exists? %>
  <div class="max-w-xl mx-auto px-2 py-3 flex flex-col gap-4">
    <div class="bg-white shadow-sm border border-slate-100 p-4">
      <%= column_chart @user.food_entries.order(:date).group(:date).sum(:calories), title: "Calories Consumption By Day" %>
    </div>
  </div>
<% end %>
