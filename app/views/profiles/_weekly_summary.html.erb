<%
  summary = WeeklyHealthSummaryPresenter.new(@user)
%>


<div class="max-w-xl mx-auto px-2 py-3 mb-1">
  <div class="bg-white shadow-sm border border-slate-200 rounded-lg p-4">
    <h2 class="font-semibold text-slate-800 mb-2">
      Your Weekly Summary
    </h2>

    <div class="grid grid-cols-3 gap-3 mb-4">
      <div class="bg-slate-50 rounded-xl p-3 flex flex-col">
        <p class="text-xs text-slate-400 uppercase tracking-wide mb-1">Avg. daily calories</p>
        <%= avg_daily_calories_label(summary.avg_daily_calories) %>
        <%= calorie_diff_label(summary.calorie_diff) %>
      </div>

      <div class="bg-slate-50 rounded-xl p-3 flex flex-col">
        <p class="text-xs text-slate-400 uppercase tracking-wider mb-1">Weight change</p>
        <%= weight_change_label(summary.weight_change) %>
        <%= weight_change_diff(summary.weight_change) %>
      </div>

      <div class="bg-slate-50 rounded-xl p-3 flex flex-col">
        <p class="text-xs text-slate-400 uppercase tracking-wider mb-1">Avg. blood pressure</p>
        <%= avg_blood_pressure_label(summary.avg_blood_pressure) %>
        <%= blood_pressure_diff(summary.avg_blood_pressure, summary.previous_week.avg_blood_pressure) %>
      </div>
    </div>

    <p class="text-xs text-slate-500 pt-4 border-t border-slate-100">
      <% if summary.days_logged == 7 %>
        Perfect logging week — all 7 days tracked across food, weight, and BP.
      <% else %>
        You logged <%= number_to_sequence(summary.days_logged) %> in 7 days. Consistent logging gives you more accurate insights.
      <% end %>
    </p>

  </div>
</div>
