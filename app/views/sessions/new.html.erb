<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4">
  <div class="w-full max-w-sm">

    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-slate-800">Welcome back</h1>
      <p class="text-sm text-slate-400 mt-1">Sign in to your account</p>
    </div>

    <% if alert = flash[:alert] %>
      <div class="mb-4 px-4 py-3 bg-red-50 border border-red-200
                  text-red-700 text-sm rounded-lg">
        <%= alert %>
      </div>
    <% end %>

    <% if notice = flash[:notice] %>
      <div class="mb-4 px-4 py-3 bg-emerald-50 border border-emerald-200
                  text-emerald-700 text-sm rounded-lg">
        <%= notice %>
      </div>
    <% end %>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
      <%= form_with url: session_url do |f| %>
        <div class="flex flex-col gap-4">

          <div class="flex flex-col gap-1">
            <%= f.label :email_address, "Email",
                  class: "text-xs font-semibold uppercase tracking-widest text-slate-400" %>
            <%= f.email_field :email_address,
                  required: true,
                  autofocus: true,
                  autocomplete: "username",
                  placeholder: "you@example.com",
                  value: params[:email_address],
                  class: "text-sm rounded-lg border border-slate-200 px-3 py-2
                          text-slate-700 placeholder-slate-300
                          focus:outline-none focus:ring-2 focus:ring-emerald-400
                          focus:border-transparent transition" %>
          </div>

          <div class="flex flex-col gap-1">
            <%= f.label :password, "Password",
                  class: "text-xs font-semibold uppercase tracking-widest text-slate-400" %>
            <%= f.password_field :password,
                  required: true,
                  autocomplete: "current-password",
                  placeholder: "Enter your password",
                  maxlength: 72,
                  class: "text-sm rounded-lg border border-slate-200 px-3 py-2
                          text-slate-700 placeholder-slate-300
                          focus:outline-none focus:ring-2 focus:ring-emerald-400
                          focus:border-transparent transition" %>
          </div>

          <%= f.button "Sign in",
                class: "w-full text-sm font-medium bg-emerald-500 hover:bg-emerald-600
                        text-white px-4 py-2.5 rounded-lg transition-colors cursor-pointer mt-2" %>

        </div>
      <% end %>
    </div>

    <div class="flex items-center justify-between mt-6 text-sm text-slate-400">
      <p>
        No account?
        <%= link_to "Sign up", new_registration_path,
              class: "text-emerald-600 hover:text-emerald-700 font-medium transition-colors" %>
      </p>
      <%= link_to "Forgot password?", new_password_path,
            class: "hover:text-slate-600 transition-colors" %>
    </div>

  </div>
</div>
