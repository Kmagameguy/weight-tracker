<div class="max-w-xl mx-auto px-4 py-4 flex items-center justify-between">
  <%= link_to day_path_for(@day_presenter.prev_day),
        id: "prev-day-nav",
        class: "flex items-center gap-1 select-none text-sm
                text-slate-400 hover:text-slate-700 transition-colors" do %>
    <span class="select-none">&larr;</span>
    <span class="select-none"><%= @day_presenter.prev_day.strftime("%b %-d") %></span>
  <% end %>

  <div class="text-center">
    <h1 class="text-lg select-none font-semibold text-slate-800">
      <%= @day_presenter.date.strftime("%B %-d") %>
    </h1>
    <p class="text-xs text-slate-400 select-none"><%= @day_presenter.date.strftime("%A, %Y") %></p>
  </div>

  <% unless @day_presenter.today? %>
    <%= link_to day_path_for(@day_presenter.next_day),
          id: "next-day-nav",
          class: "flex items-center gap-1 text-sm select-none
                  text-slate-400 hover:text-slate-700 transition-colors" do %>
      <span class="select-none"><%= @day_presenter.next_day.strftime("%b %-d") %></span>
      <span class="select-none">&rarr;</span>
    <% end %>
  <% end %>
</div>

<div class="max-w-xl mx-auto px-4 py-6 flex flex-col gap-4">

  <% if alert %>
    <div class="px-4 py-3 bg-red-50 border border-red-200 text-red-700
                text-sm rounded-lg">
      <%= alert %>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100">
    <%= render "days/calories_summary", day_presenter: @day_presenter %>
    <div class="px-6 py-2">
      <div id="food_entries" class="divide-y divide-slate-50">
        <%= render @day_presenter.food_entries %>
        <% unless @day_presenter.food_entries.any? %>
          <%= render "food_entries/empty" %>
        <% end %>
      </div>
    </div>

    <div id="food_entry_form" class="px-6 pb-6 pt-2 border-t border-slate-50">
      <%= render "food_entries/form", food_entry: @day_presenter.new_food_entry %>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <%= turbo_frame_tag "weight_entry" do %>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4 select-none">
        <%= last_weigh_in(@day_presenter) %>
        <p>Today's Weigh-in</p>
      </h2>
      <% if @day_presenter.weight_entry %>
        <%= render "weight_entries/weight_entry", weight_entry: @day_presenter.weight_entry %>
      <% else %>
        <%= render "weight_entries/form", weight_entry: @day_presenter.new_weight_entry %>
      <% end %>
    <% end %>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <%= turbo_frame_tag "blood_pressure_reading" do %>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4 select-none">
        <%= last_blood_pressure_reading(@day_presenter) %>
        <p>Today's BP Reading</p>
      </h2>
      <% if @day_presenter.blood_pressure_reading %>
        <%= render "blood_pressure_readings/blood_pressure_reading", blood_pressure_reading: @day_presenter.blood_pressure_reading %>
      <% else %>
        <%= render "blood_pressure_readings/form", blood_pressure_reading: @day_presenter.new_blood_pressure_reading %>
      <% end %>
    <% end %>
  </div>
</div>
