<header class="sticky top-0 z-10 bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-xl mx-auto px-4 pb-0 flex gap-3 items-center justify-end">
    <%= link_to Current.user.email_address, profile_path,
          class: "text-xs text-slate-400 hover:text-red-400 transition-colors
                  cursor-pointer p-0" %>

    <%= button_to "Sign out", session_path(Current.session),
          method: :delete,
          class: "text-xs text-slate-400 hover:text-red-400 transition-colors
                  bg-transparent border-0 cursor-pointer p-0" %>
  </div>

  <div class="max-w-xl mx-auto px-4 py-4 flex items-center justify-between">
    <%= link_to day_path_for(@day_presenter.prev_day),
          class: "flex items-center gap-1 text-sm text-slate-400
                  hover:text-slate-700 transition-colors" do %>
      <span>&larr;</span>
      <span><%= @day_presenter.prev_day.strftime("%b %-d") %></span>
    <% end %>

    <div class="text-center">
      <h1 class="text-lg font-semibold text-slate-800">
        <%= @day_presenter.date.strftime("%B %-d") %>
      </h1>
      <p class="text-xs text-slate-400"><%= @day_presenter.date.strftime("%A, %Y") %></p>
    </div>

    <% unless @day_presenter.today? %>
      <%= link_to day_path_for(@day_presenter.next_day),
            class: "flex items-center gap-1 text-sm text-slate-400
                    hover:text-slate-700 transition-colors" do %>
        <span><%= @day_presenter.next_day.strftime("%b %-d") %></span>
        <span>&rarr;</span>
      <% end %>
    <% end %>
  </div>
</header>

<div class="max-w-xl mx-auto px-4 py-6 flex flex-col gap-4">

  <% if alert %>
    <div class="px-4 py-3 bg-red-50 border border-red-200 text-red-700
                text-sm rounded-lg">
      <%= alert %>
    </div>
  <% end %>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100">
    <%= render "days/calories_summary", day_presenter: @day_presenter %>
    <div class="px-6 py-2">
      <% if @day_presenter.food_entries.any? %>
        <div id="food_entries" class="divide-y divide-slate-50">
          <%= render @day_presenter.food_entries %>
        </div>
      <% else %>
        <p class="text-sm text-slate-300 py-4">Nothing logged yet today.</p>
      <% end %>
    </div>

    <div id="food_entry_form" class="px-6 pb-6 pt-2 border-t border-slate-50">
      <%= render "food_entries/form", food_entry: @day_presenter.new_food_entry %>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
    <%= turbo_frame_tag "weight_entry" do %>
      <h2 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">
        <p>Last weigh-in: <%= @day_presenter.last_weight_entry ? "#{@day_presenter.last_weight_entry.weight} - #{@day_presenter.last_weight_entry.date.strftime("%B %-d")}" : "No weigh-ins yet." %></p>
        <p>Today's Weigh-in</p>
      </h2>
      <% if @day_presenter.weight_entry %>
        <%= render "weight_entries/weight_entry", weight_entry: @day_presenter.weight_entry %>
      <% else %>
        <%= render "weight_entries/form", weight_entry: @day_presenter.new_weight_entry %>
      <% end %>
    <% end %>
  </div>
</div>
