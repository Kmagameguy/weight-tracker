<%
  first_day    = date.beginning_of_month
  last_day     = date.end_of_month
  start_offset = (first_day.wday - 1) % 7
  today        = Date.today
%>

<div class="flex items-center justify-between mb-3">
  <%= link_to calendar_path(year: (date - 1.month).year, month: (date - 1.month).month),
        data: { turbo_frame: "calendar_frame" },
        class: "text-slate-400 hover:text-slate-700 px-2 transition-colors text-base" do %>
    &larr;
  <% end %>

  <span class="text-sm font-semibold text-slate-700">
    <%= date.strftime("%B %Y") %>
  </span>

  <% if date.year < today.year || (date.year == today.year && date.month < today.month) %>
    <%= link_to calendar_path(year: (date + 1.month).year, month: (date + 1.month).month),
          data: { turbo_frame: "calendar_frame" },
          class: "text-slate-400 hover:text-slate-700 px-2 transition-colors text-base" do %>
      &rarr;
    <% end %>
  <% else %>
    <span class="px-2 text-base text-slate-200">&rarr;</span>
  <% end %>
</div>

<div style="display:grid; grid-template-columns:repeat(7, 1fr);" class="mb-1">
  <% %w[Mo Tu We Th Fr Sa Su].each do |d| %>
    <div class="text-center text-xs font-medium text-slate-400 py-1"><%= d %></div>
  <% end %>
</div>

<div style="display:grid; grid-template-columns:repeat(7, 1fr); row-gap:2px;">
  <% start_offset.times do %>
    <div></div>
  <% end %>

  <% (first_day..last_day).each do |day| %>
    <%
      is_today    = day == today
      is_selected = day == date
      is_future   = day > today
    %>

    <% if is_future %>
      <div style="display:flex; align-items:center; justify-content:center; height:2rem; width:2rem; margin:0 auto; color:#cbd5e1; cursor:not-allowed;"
           class="rounded-full text-xs">
        <%= day.day %>
      </div>
    <% else %>
      <%= link_to day_path_for(day),
            data: { turbo_frame: "_top" },
            style: "display:flex; align-items:center; justify-content:center; height:2rem; width:2rem; margin:0 auto;",
            class: [
              "text-xs rounded-full transition-colors",
              if is_selected
                "bg-emerald-500 text-white font-semibold"
              elsif is_today
                "bg-emerald-100 text-emerald-700 font-medium"
              else
                "text-slate-600 hover:bg-slate-100"
              end
            ].join(" ") do %>
        <%= day.day %>
      <% end %>
    <% end %>
  <% end %>
</div>

<% unless date.month == today.month && date.year == today.year %>
  <div class="mt-3 pt-3 border-t border-slate-100 text-center">
    <%= link_to "Today", day_path_for(today),
          data: { turbo_frame: "_top" },
          class: "text-xs text-emerald-600 hover:text-emerald-700 font-medium transition-colors" %>
  </div>
<% end %>
