<section id="calendar_grid">
  <div class="flex items-center justify-between mb-3">
    <%= link_to calendar_path(year: calendar.prev_month.year, month: calendar.prev_month.month),
          data: { turbo_frame: "calendar_frame" },
          class: "text-slate-400 hover:text-slate-700 px-2 transition-colors text-base" do %>
      &larr;
    <% end %>

    <span class="text-sm font-semibold text-slate-700">
      <%= calendar.date.strftime("%B %Y") %>
    </span>

    <% if calendar.current_month? %>
      <span class="cursor-not-allowed px-2 text-base text-slate-200">&rarr;</span>
    <% else %>
      <%= link_to calendar_path(year: calendar.next_month.year, month: calendar.next_month.month),
            data: { turbo_frame: "calendar_frame" },
            class: "text-slate-400 hover:text-slate-700 px-2 transition-colors text-base" do %>
        &rarr;
      <% end %>
    <% end %>
  </div>

  <div class="calendar-grid-headers mb-1">
    <% CalendarPresenter::WEEK_DAY_HEADERS.each do |day| %>
      <div class="text-center text-xs font-medium text-slate-400 py-1"><%= day %></div>
    <% end %>
  </div>

  <div class="calendar-grid">
    <% calendar.start_offset.times do %>
      <div></div>
    <% end %>

    <% calendar.days.each do |day| %>
      <% case calendar.day_status(day) %>
      <% when :future %>
        <div class="calendar-day-future cursor-not-allowed rounded-full text-xs">
          <%= day.day %>
        </div>
      <% when :selected %>
        <%= link_to day_path_for(day),
              data: { turbo_frame: "_top" },
              class: "calendar-day-selected
                      text-xs rounded-full transition-colors
                      bg-emerald-500 text-white font-semibold" do %>
          <%= day.day %>
        <% end %>
      <% when :today %>
        <%= link_to day_path_for(day),
              data: { turbo_frame: "_top" },
              class: "flex items-center justify-center h-8 w-8 mx-auto
                      text-xs rounded-full transition-colors
                      bg-emerald-100 text-emerald-700 font-medium" do %>
          <%= day.day %>
        <% end %>
      <% when :default %>
        <%= link_to day_path_for(day),
              data: { turbo_frame: "_top" },
              class: "flex items-center justify-center h-8 w-8 mx-auto
                      text-xs rounded-full transition-colors
                      text-slate-600 hover:bg-slate-100" do %>
          <%= day.day %>
        <% end %>
      <% end %>
    <% end %>
  </div>

  <% unless calendar.current_month? %>
    <div class="mt-3 pt-3 border-t border-slate-100 text-center">
      <%= link_to "Today", day_path_for(calendar.today),
            data: { turbo_frame: "_top" },
            class: "text-xs text-emerald-600 hover:text-emerald-700 font-medium transition-colors" %>
    </div>
  <% end %>
</section>
